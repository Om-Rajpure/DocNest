# =============================================
# DocNest — .gitignore
# =============================================

# ---------- Frontend (React / Vite) ----------
docnest-frontend/node_modules/
docnest-frontend/dist/
docnest-frontend/.env
docnest-frontend/.env.local
docnest-frontend/.env.*.local

# ---------- Backend (Spring Boot / Maven) ----------
docnest-backend/target/
docnest-backend/.mvn/wrapper/maven-wrapper.jar
docnest-backend/*.jar
docnest-backend/.env

# ---------- Uploads (runtime files) ----------
docnest-backend/uploads/

# ---------- IDE ----------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Misc ----------
*.tmp
*.bak
*.swp
*~
